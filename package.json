{
  "name": "nigeria-history-pipeline",
  "version": "0.1.0",
  "description": "AI-driven Nigerian history content pipeline for The Lens Facebook page.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "ts-node src/db/migrate.ts",
    "cli:fetch-story": "ts-node src/cli/fetch-story.ts",
    "cli:generate-post": "ts-node src/cli/generate-post.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  }
}
