# Nigeria History Pipeline — required environment variables
# Copy this to .env and populate for local development.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/nigeria_history

# ── Facebook ──────────────────────────────────────────────────────────────
# Obtain from Facebook Developer Console after rotating compromised credentials.
# Store production values in AWS Secrets Manager or HashiCorp Vault — NOT here.
FACEBOOK_APP_SECRET=<rotated-app-secret>
FACEBOOK_PAGE_ACCESS_TOKEN=<rotated-page-access-token>

# Facebook Page ID (public, not secret)
FACEBOOK_PAGE_ID=61577657207009

# ── Anthropic ─────────────────────────────────────────────────────────────
# Required for content generation (Module 3).
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Secrets Manager ───────────────────────────────────────────────────────
# In production, set this to point at your secrets manager.
# Leave blank for local dev to use env vars directly.
# SECRETS_MANAGER_ENDPOINT=

# ── Autonomous pipeline (v2) ───────────────────────────────────────────────
# Slack incoming webhook URL for pipeline notifications (run start, approvals, publish, errors).
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Number of published posts before the approval gate auto-disables (default: 20).
# Once this many clean posts are published, the pipeline goes fully autonomous.
APPROVAL_THRESHOLD=20

# URL of the publish-approved GitHub Actions workflow.
# Pasted into Slack approval notifications so reviewers can click directly to approve.
# Format: https://github.com/<owner>/<repo>/actions/workflows/publish-approved.yml
GITHUB_WORKFLOW_URL=https://github.com/<owner>/<repo>/actions/workflows/publish-approved.yml

# ISO date when the current Facebook long-lived page token was created (e.g. 2026-04-19).
# Used by check-snapshots to warn via Slack when the token is older than 50 days.
# Update this whenever you rotate the token.
FACEBOOK_TOKEN_CREATED_AT=2026-04-19
