# Nigeria History Pipeline — required environment variables
# Copy this to .env and populate for local development.
# NEVER commit .env to version control.
#
# ── Secrets management ────────────────────────────────────────────────────────
# All production secrets are managed via Doppler.
# Install the Doppler CLI: https://docs.doppler.com/docs/install-cli
# Local dev:   doppler run -- npm run <script>
# GitHub CI:   Doppler GitHub Actions integration syncs secrets automatically.
# Supabase:    Use `doppler secrets download` in the Edge Function deploy step.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (free tier is sufficient for this pipeline).
# Format: postgres://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://user:password@localhost:5432/nigeria_history

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service role key — used by the slack-interaction Edge Function.
# Find these at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Facebook ──────────────────────────────────────────────────────────────────
# Obtain from Facebook Developer Console.
# Store production values in Doppler — NOT here.
FACEBOOK_APP_SECRET=<rotated-app-secret>
FACEBOOK_PAGE_ACCESS_TOKEN=<rotated-page-access-token>

# Facebook Page ID (public, not secret)
FACEBOOK_PAGE_ID=61577657207009

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for content generation (Module 3).
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Slack ─────────────────────────────────────────────────────────────────────
# Incoming webhook URL for pipeline notifications (run start, approvals, errors).
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Slack app signing secret — used by the slack-interaction Edge Function to
# validate that interaction payloads genuinely come from Slack.
# Find at: https://api.slack.com/apps → <your app> → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=<slack-signing-secret>

# ── GitHub (for Slack interactive approval) ───────────────────────────────────
# Personal access token (or fine-grained PAT) with `actions:write` scope.
# Used by the slack-interaction Supabase Edge Function to trigger
# publish-approved.yml via GitHub Actions workflow_dispatch.
GITHUB_TOKEN=<github-pat-with-actions-write>

# GitHub repo coordinates — used by the slack-interaction Edge Function.
GITHUB_OWNER=<github-owner-or-org>
GITHUB_REPO=<github-repo-name>

# ── Autonomous pipeline ───────────────────────────────────────────────────────
# Number of published posts before the approval gate auto-disables (default: 20).
# Once this many clean posts are published, the pipeline goes fully autonomous.
APPROVAL_THRESHOLD=20

# ISO date when the current Facebook long-lived page token was created (e.g. 2026-04-19).
# Used by check-snapshots to warn via Slack when the token is older than 50 days.
# Update this whenever you rotate the token.
FACEBOOK_TOKEN_CREATED_AT=2026-04-19
